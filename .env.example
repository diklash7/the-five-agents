# ============================================================
# The Five Agents — Environment Variables (Example)
# ============================================================
# Copy this file to .env and fill in your real values.
# This file IS committed to git — never put real keys here.
# ============================================================

# --- Anthropic ---
# Required for all agents (Ohad, Yuval, and future agents)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Google Gemini (Nano Banana 2 MCP) ---
# Required for Yuval's image generation via nano-banana-2 MCP
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
